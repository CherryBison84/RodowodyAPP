{
  "project_name": "demo_clean_batch",
  "output_dir": "outputs",
  "stages": ["load", "validate", "transform", "export"],
  "inputs": [
    {
      "name": "default_ebpb",
      "path": "data/EBPB_bison_report.xlsx"
    }
  ],
  "rules": {
    "apply_auto_fix": true,
    "exclude_test_records": true,
    "auto_fix": {
      "dedupe_ids": true,
      "cut_missing_parent_record": true,
      "cut_parent_sex_collision": true
    }
  },
  "output": {
    "export_format": "xlsx"
  }
}
